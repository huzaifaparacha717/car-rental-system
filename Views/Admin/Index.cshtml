@model car_rental_system.Models.AdminDashboardViewModel
@{
    ViewData["Title"] = "Dashboard";
}

<h1 class="h3 mb-4 text-dark">Dashboard</h1>

<div class="row g-3 mb-4">
    <div class="col-sm-6 col-xl-3">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body">
                <div class="text-muted small text-uppercase">Total cars</div>
                <div class="display-6 fw-bold text-primary">@Model.TotalCars</div>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body">
                <div class="text-muted small text-uppercase">Available</div>
                <div class="display-6 fw-bold text-success">@Model.AvailableCars</div>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body">
                <div class="text-muted small text-uppercase">Booked</div>
                <div class="display-6 fw-bold text-warning">@Model.BookedCars</div>
            </div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body">
                <div class="text-muted small text-uppercase">Registered users</div>
                <div class="display-6 fw-bold text-dark">@Model.RegisteredUsers</div>
            </div>
        </div>
    </div>
</div>

<div class="card border-0 shadow-sm">
    <div class="card-body">
        <h2 class="h5 mb-3">Quick actions</h2>
        <div class="d-flex flex-wrap gap-2">
            <a asp-action="Cars" class="btn btn-outline-primary"><i class="bi bi-list-ul me-1"></i>Manage fleet</a>
            <a asp-controller="Car" asp-action="Create" class="btn btn-primary"><i class="bi bi-plus-lg me-1"></i>Add car</a>
            <a asp-controller="Car" asp-action="Index" class="btn btn-outline-secondary">View public catalog</a>
        </div>
    </div>
</div>
